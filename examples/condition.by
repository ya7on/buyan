import std.cfg;
import std.math;
import std.io;

module app;

def main(--)
    // Add two numbers to the stack and count the sum of them.
    2u8 2u8
    std.math.add

    // Check if the top of the stack is equal to 4.
    4u8 std.math.eq

    // If the condition is true, print "2 + 2 = 4".
    // If the condition is false, print "Never be printed".
    | -- | { "2 + 2 = 4" std.io.println }
    | -- | { "Never be printed" std.io.println }
    std.cfg.if
end
